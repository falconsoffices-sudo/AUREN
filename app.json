{
  "expo": {
    "name": "AUREN",
    "slug": "auren",
    "version": "1.0.0",
    "description": "Gestão completa para profissionais de manicure",
    "orientation": "portrait",
    "icon": "./assets/images/emblema.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/emblema.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A0A14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.falcons.auren",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.falcons.auren",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/emblema.png",
        "backgroundColor": "#1A0A14"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
